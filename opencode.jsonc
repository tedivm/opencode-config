{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/anthropic",
      "name": "vLLM",
      "options": {
        "baseURL": "{file:.llm_host}",
        "chunkTimeout": 18000000,
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27b",
          "limit": {
            "context": 200000,
            "output": 20000,
          },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
        },
      },
    },
  },
  "enabled_providers": ["vllm"],
  "model": "vllm/qwen3.6-27b",
  "small_model": "vllm/qwen3.6-27b",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:.context7-api-key}",
      },
    },
    "svelte": {
      "type": "local",
      "command": ["npx", "-y", "@sveltejs/mcp"],
    },
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
}
